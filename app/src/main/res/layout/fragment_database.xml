<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1024dp"
    android:layout_height="768dp"
    android:orientation="horizontal"
    tools:context=".pages.DatabaseFragment">

    <!-- 테이블 선택 -->
    <Spinner
        android:id="@+id/spinnerTable"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:dropDownWidth="300dp"
        android:spinnerMode="dropdown"
        android:theme="@style/SpinnerTheme"
        android:background="@drawable/spinner_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 조회 버튼 -->
    <Button
        android:id="@+id/btnQuery"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginStart="6dp"
        android:text="조회"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/shape_btn_blue"
        app:backgroundColor="@null"
        app:layout_constraintTop_toTopOf="@id/spinnerTable"
        app:layout_constraintStart_toEndOf="@id/spinnerTable" />

    <!-- 행 수 표시 -->
    <TextView
        android:id="@+id/tvRowCount"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#999999"
        app:layout_constraintTop_toTopOf="@id/spinnerTable"
        app:layout_constraintStart_toEndOf="@id/btnQuery" />

    <!-- 닫기 버튼 -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:text="@string/exit"
        android:textColor="@color/primary"
        app:backgroundTint="@null"
        android:textSize="20sp"
        android:background="@drawable/selector_default_btn"
        app:layout_constraintTop_toTopOf="@id/spinnerTable"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 구분선 -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#333333"
        app:layout_constraintTop_toBottomOf="@id/spinnerTable"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 빈 상태 안내 -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="테이블을 선택하고 조회 버튼을 누르세요"
        android:textColor="#666666"
        android:textSize="14sp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 테이블 영역 (헤더 + 데이터 가로 동기 스크롤) -->
    <HorizontalScrollView
        android:id="@+id/scrollH"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:scrollbars="horizontal"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 컬럼 헤더 행 -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="#1e1e1e" />

            <!-- 헤더 하단 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444" />

            <!-- 데이터 행 (세로 스크롤) -->
            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/dataContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>
        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>