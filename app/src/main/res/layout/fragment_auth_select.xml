<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="512dp"
    android:layout_height="662dp"
    tools:context=".pages.AuthSelectFragment">

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/layer_list_rect"
        tools:layout_editor_absoluteX="5dp"
        tools:layout_editor_absoluteY="5dp" />

    <!-- member info -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewMember"
        android:layout_width="450dp"
        android:layout_height="120dp"
        android:layout_marginTop="56dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/layer_list_rect_corner">

            <TextView
                android:id="@+id/textViewMember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/memberMessage"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black_500"
                app:layout_constraintTop_toTopOf="@id/imageViewMember"
                app:layout_constraintStart_toEndOf="@id/imageViewMember"  />

            <ImageView
                android:id="@+id/imageViewMember"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/member"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewMemberUnitInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="0원/kWh"
                android:textSize="18sp"
                android:textColor="@color/black_600"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewMember"
                app:layout_constraintBottom_toBottomOf="@id/textViewMember" />

            <TextView
                android:id="@+id/textViewMemberContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="@string/memberInfoMessage"
                android:textSize="20sp"
                android:textColor="@color/black_500"
                app:layout_constraintTop_toBottomOf="@id/textViewMember"
                app:layout_constraintStart_toStartOf="@id/textViewMember" />


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>



    <!-- nomember info -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewNoMember"
        android:layout_width="450dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardViewMember"
        app:layout_constraintStart_toStartOf="@id/cardViewMember"
        app:layout_constraintEnd_toEndOf="@id/cardViewMember">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/layer_list_rect_corner">

            <TextView
                android:id="@+id/textViewNoMember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/nomemberMessage"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black_500"
                app:layout_constraintTop_toTopOf="@id/imageViewNoMember"
                app:layout_constraintStart_toEndOf="@id/imageViewNoMember"/>

            <ImageView
                android:id="@+id/imageViewNoMember"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/nomember"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewNoMemberUnitInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="0원/kWh"
                android:textSize="18sp"
                android:textColor="@color/black_600"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewNoMember"
                app:layout_constraintBottom_toBottomOf="@id/textViewNoMember" />

            <TextView
                android:id="@+id/textViewNoMemberContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="@string/nomemberInfoMessage"
                android:textSize="20sp"
                android:textColor="@color/black_500"
                app:layout_constraintStart_toStartOf="@id/textViewNoMember"
                app:layout_constraintTop_toBottomOf="@id/textViewNoMember" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!--  법인  -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewCorp"
        android:layout_width="450dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardViewNoMember"
        app:layout_constraintStart_toStartOf="@id/cardViewNoMember"
        app:layout_constraintEnd_toEndOf="@id/cardViewNoMember">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/layer_list_rect_corner">

            <TextView
                android:id="@+id/textViewCorp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/corpMessage"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black_500"
                app:layout_constraintTop_toTopOf="@id/imageViewCorp"
                app:layout_constraintStart_toEndOf="@id/imageViewCorp"/>

            <ImageView
                android:id="@+id/imageViewCorp"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/corp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewCorpUnitInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="0원/kWh"
                android:textSize="18sp"
                android:textColor="@color/black_600"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewCorp"
                app:layout_constraintBottom_toBottomOf="@id/textViewCorp" />

            <TextView
                android:id="@+id/textViewCorpContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="@string/corpInfoMessage"
                android:textSize="20sp"
                android:textColor="@color/black_500"
                app:layout_constraintStart_toStartOf="@id/textViewCorp"
                app:layout_constraintTop_toBottomOf="@id/textViewCorp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!--  환경부  -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewKeco"
        android:layout_width="450dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardViewCorp"
        app:layout_constraintStart_toStartOf="@id/cardViewCorp"
        app:layout_constraintEnd_toEndOf="@id/cardViewCorp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/layer_list_rect_corner">

            <TextView
                android:id="@+id/textViewKeco"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/kecoMessage"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black_500"
                app:layout_constraintTop_toTopOf="@id/imageViewKeco"
                app:layout_constraintStart_toEndOf="@id/imageViewKeco"/>

            <ImageView
                android:id="@+id/imageViewKeco"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/keco"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewKecoUnitInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="0원/kWh"
                android:textSize="18sp"
                android:textColor="@color/black_600"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewKeco"
                app:layout_constraintBottom_toBottomOf="@id/textViewKeco" />

            <TextView
                android:id="@+id/textViewKecoContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="@string/kecoInfoMessage"
                android:textSize="20sp"
                android:textColor="@color/black_500"
                app:layout_constraintStart_toStartOf="@id/textViewKeco"
                app:layout_constraintTop_toBottomOf="@id/textViewKeco" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>