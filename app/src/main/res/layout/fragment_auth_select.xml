<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="512dp"
    android:layout_height="662dp"
    tools:context=".pages.AuthSelectFragment">

    <!-- member info -->
    <View
        android:id="@+id/viewMember"
        android:layout_width="450dp"
        android:layout_height="240dp"
        android:layout_marginTop="60dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/layer_list_rect_corner"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textViewMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/memberMessage"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/black_500"
        app:layout_constraintTop_toTopOf="@id/viewMember"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="@id/viewMember" />

    <ImageView
        android:id="@+id/imageViewMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/member"
        app:layout_constraintTop_toBottomOf="@id/textViewMember"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewMemberUnitInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="-12dp"
        android:text="충전단가: 310원"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@id/imageViewMember"
        app:layout_constraintTop_toTopOf="@id/imageViewMember" />

    <TextView
        android:id="@+id/textViewMemberContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="start"
        android:text="@string/memberInfoMessage"
        android:textSize="22sp"
        android:textColor="@color/black_500"
        app:layout_constraintTop_toBottomOf="@id/textViewMemberUnitInput"
        app:layout_constraintStart_toStartOf="@id/textViewMemberUnitInput" />


    <!-- nomember info -->
    <View
        android:id="@+id/viewNoMember"
        android:layout_width="450dp"
        android:layout_height="240dp"
        android:layout_marginTop="52dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/layer_list_rect_corner"
        app:layout_constraintTop_toBottomOf="@id/viewMember"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="@id/viewMember"/>

    <TextView
        android:id="@+id/textViewNoMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/nomemberMessage"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black_500"
        app:layout_constraintTop_toTopOf="@id/viewNoMember"
        app:layout_constraintStart_toStartOf="@id/viewNoMember"
        app:layout_constraintEnd_toEndOf="@id/viewNoMember"/>

    <ImageView
        android:id="@+id/imageViewNoMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/nomember"
        app:layout_constraintTop_toBottomOf="@id/textViewNoMember"
        app:layout_constraintStart_toStartOf="@id/viewNoMember"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewNoMemberUnitInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="-12dp"
        android:text="충전단가: 480원"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@id/imageViewNoMember"
        app:layout_constraintTop_toTopOf="@id/imageViewNoMember" />

    <TextView
        android:id="@+id/textViewNoMemberContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="start"
        android:text="@string/nomemberInfoMessage"
        android:textSize="22sp"
        android:textColor="@color/black_500"
        app:layout_constraintStart_toStartOf="@id/textViewNoMemberUnitInput"
        app:layout_constraintTop_toBottomOf="@id/textViewNoMemberUnitInput" />

</androidx.constraintlayout.widget.ConstraintLayout>